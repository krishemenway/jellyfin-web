    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/recharts": "^2.0.1",
    "date-fns": "^4.1.0",
    "esbuild": "0.25.10",
    "eslint": "^9.31.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "^5.2.1",
    "express-http-proxy": "^2.1.2",
    "globals": "^16.3.0",
